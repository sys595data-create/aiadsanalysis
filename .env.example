# ── Database (Railway PostgreSQL auto-sets this) ──────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Cloudflare R2 ─────────────────────────────────────────────────────────────
R2_ACCOUNT_ID=bf31bd9906297eadf7a161ebbb213a81
R2_ACCESS_KEY_ID=2e7e0624375ceb84b760c0807c4b3eeb
R2_SECRET_ACCESS_KEY=5b1c309c25fbd3fdc2d98cef77e359bed7793d381f334ba532bc24f1481ed81a
R2_BUCKET_NAME=aiadsanalysis

# ── RunPod ────────────────────────────────────────────────────────────────────
RUNPOD_API_KEY=your_runpod_api_key
RUNPOD_ENDPOINT_ID=your_endpoint_id

# ── pipispy (PiPiADS) — TikTok ad API ────────────────────────────────────────
PIPISPY_API_KEY=your_pipispy_api_key
PIPISPY_BASE_URL=https://api.pipiads.com/api/v1

# ── Minea — Instagram ad intelligence ────────────────────────────────────────
MINEA_EMAIL=your@email.com
MINEA_PASSWORD=yourpassword
MINEA_PROFILE_DIR=.minea_profile

# ── Reddit (optional — falls back to public JSON if not set) ──────────────────
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=aiadsanalysis/1.0

# ── YouTube (optional — yt-dlp works without) ────────────────────────────────
YOUTUBE_API_KEY=

# ── Groq LLM synthesis ────────────────────────────────────────────────────────
GROK_API_KEY=your_groq_api_key
GROK_API_BASE=https://api.groq.com/openai/v1

# ── Proxy (optional — for Amazon/Walmart anti-bot) ───────────────────────────
PROXY_URL=

# ── YOLO ─────────────────────────────────────────────────────────────────────
YOLO_MODEL_PATH=/models/best.pt
YOLO_MODE=yolo

# ── Frontend URL (set after Railway frontend deploys) ─────────────────────────
FRONTEND_URL=https://your-frontend.railway.app

# ── Frontend only ─────────────────────────────────────────────────────────────
BACKEND_URL=https://your-backend.railway.app
